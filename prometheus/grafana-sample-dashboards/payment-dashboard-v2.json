{
  "apiVersion": "dashboard.grafana.app/v2",
  "kind": "Dashboard",
  "metadata": {
    "name": "payment-platform-v2",
    "namespace": "default"
  },
  "spec": {
    "editable": true,
    "elements": {
      "panel-edge-http": {
        "kind": "Panel",
        "spec": {
          "id": 1,
          "title": "Edge - HTTP Requests Per Second",
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "query": {
                      "kind": "DataQuery",
                      "group": "prometheus",
                      "datasource": { "name": "prometheus" },
                      "spec": {
                        "expr": "sum(rate(http_server_requests_seconds_count{application=\"payment-service\", uri!~\"/actuator.*\"}[1m]))",
                        "legendFormat": "{{pod}}"
                      }
                    },
                    "refId": "A"
                  }
                }
              ]
            }
          },
          "vizConfig": {
            "kind": "VizConfig",
            "group": "timeseries",
            "spec": {}
          }
        }
      },
      "panel-edge-forward": {
        "kind": "Panel",
        "spec": {
          "id": 2,
          "title": "Edge - Local Outbox Forward Rate",
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "query": {
                      "kind": "DataQuery",
                      "group": "prometheus",
                      "datasource": { "name": "prometheus" },
                      "spec": {
                        "expr": "sum(rate(outbox_dispatched_total[1m])) by (pod)",
                        "legendFormat": "{{pod}} (success)"
                      }
                    },
                    "refId": "A"
                  }
                },
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "query": {
                      "kind": "DataQuery",
                      "group": "prometheus",
                      "datasource": { "name": "prometheus" },
                      "spec": {
                        "expr": "sum(rate(outbox_dispatch_failed_total[1m])) by (pod)",
                        "legendFormat": "{{pod}} (failed)"
                      }
                    },
                    "refId": "B"
                  }
                }
              ]
            }
          },
          "vizConfig": {
            "kind": "VizConfig",
            "group": "timeseries",
            "spec": {}
          }
        }
      },
      "panel-central-backlog": {
        "kind": "Panel",
        "spec": {
          "id": 3,
          "title": "Central - Outbox Backlog Size (Target: 0)",
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "query": {
                      "kind": "DataQuery",
                      "group": "prometheus",
                      "datasource": { "name": "prometheus" },
                      "spec": {
                        "expr": "max(central_outbox_backlog_size)",
                        "legendFormat": "Global Backlog"
                      }
                    },
                    "refId": "A"
                  }
                }
              ]
            }
          },
          "vizConfig": {
            "kind": "VizConfig",
            "group": "timeseries",
            "spec": {}
          }
        }
      },
      "panel-central-relay": {
        "kind": "Panel",
        "spec": {
          "id": 4,
          "title": "Central - Outbox Relay Publish Rate",
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "query": {
                      "kind": "DataQuery",
                      "group": "prometheus",
                      "datasource": { "name": "prometheus" },
                      "spec": {
                        "expr": "sum(rate(relay_published_total[1m])) by (pod)",
                        "legendFormat": "{{pod}} (success)"
                      }
                    },
                    "refId": "A"
                  }
                },
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "query": {
                      "kind": "DataQuery",
                      "group": "prometheus",
                      "datasource": { "name": "prometheus" },
                      "spec": {
                        "expr": "sum(rate(relay_publish_failed_total[1m])) by (pod)",
                        "legendFormat": "{{pod}} (failed)"
                      }
                    },
                    "refId": "B"
                  }
                }
              ]
            }
          },
          "vizConfig": {
            "kind": "VizConfig",
            "group": "timeseries",
            "spec": {}
          }
        }
      },
      "panel-consumer-lag": {
        "kind": "Panel",
        "spec": {
          "id": 5,
          "title": "Consumers - Kafka Consumer Lag",
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "query": {
                      "kind": "DataQuery",
                      "group": "prometheus",
                      "datasource": { "name": "prometheus" },
                      "spec": {
                        "expr": "sum by (consumergroup) (kafka_consumergroup_lag{consumergroup=~\"psp-capture-executor-consumer-group|psp-refund-executor-consumer-group|psp-result-consumer-group\"})",
                        "legendFormat": "{{consumergroup}}"
                      }
                    },
                    "refId": "A"
                  }
                }
              ]
            }
          },
          "vizConfig": {
            "kind": "VizConfig",
            "group": "timeseries",
            "spec": {}
          }
        }
      },
      "panel-psp-calls": {
        "kind": "Panel",
        "spec": {
          "id": 6,
          "title": "Consumers - PSP Modification Calls Rate",
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "query": {
                      "kind": "DataQuery",
                      "group": "prometheus",
                      "datasource": { "name": "prometheus" },
                      "spec": {
                        "expr": "sum(rate(psp_calls_total[1m])) by (result)",
                        "legendFormat": "Capture ({{result}})"
                      }
                    },
                    "refId": "A"
                  }
                },
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "query": {
                      "kind": "DataQuery",
                      "group": "prometheus",
                      "datasource": { "name": "prometheus" },
                      "spec": {
                        "expr": "sum(rate(psp_refund_calls_total[1m])) by (result)",
                        "legendFormat": "Refund ({{result}})"
                      }
                    },
                    "refId": "B"
                  }
                }
              ]
            }
          },
          "vizConfig": {
            "kind": "VizConfig",
            "group": "timeseries",
            "spec": {}
          }
        }
      }
    },
    "layouts": [
      {
        "kind": "Grid",
        "spec": {
          "items": [
            { "elementId": "panel-edge-http", "x": 0, "y": 0, "w": 12, "h": 8 },
            { "elementId": "panel-edge-forward", "x": 12, "y": 0, "w": 12, "h": 8 },
            { "elementId": "panel-central-backlog", "x": 0, "y": 8, "w": 12, "h": 8 },
            { "elementId": "panel-central-relay", "x": 12, "y": 8, "w": 12, "h": 8 },
            { "elementId": "panel-consumer-lag", "x": 0, "y": 16, "w": 12, "h": 8 },
            { "elementId": "panel-psp-calls", "x": 12, "y": 16, "w": 12, "h": 8 }
          ]
        }
      }
    ]
  }
}
