<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.3.xsd">





    <changeSet id="create-edge-watermarks-table" author="antigravity">
        <createTable tableName="edge_watermarks">
            <column name="edge_node_id" type="VARCHAR(64)">
                <constraints primaryKey="true"/>
            </column>
            <column name="forwarded_up_to" type="TIMESTAMP WITHOUT TIME ZONE">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="create-payment-tx-table" author="antigravity">
        <createTable tableName="payment_tx">
            <column name="tx_id" type="BIGINT">
                <constraints primaryKey="true"/>
            </column>
            <column name="tx_type" type="VARCHAR(32)">
                <constraints nullable="false"/>
            </column>
            <column name="parent_tx_id" type="BIGINT"/>
            <column name="payment_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="payment_intent_id" type="BIGINT">
                <constraints nullable="true"/>
            </column>
            <column name="status" type="VARCHAR(16)" defaultValue="PENDING">
                <constraints nullable="false"/>
            </column>
            <column name="settle_status" type="VARCHAR(16)">
                <constraints nullable="true"/>
            </column>
            <column name="acquirer_batch_ref" type="VARCHAR(255)">
                <constraints nullable="true"/>
            </column>
            <column name="settled_amount_value" type="BIGINT">
                <constraints nullable="true"/>
            </column>
            <column name="acquirer_reference" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="amount_value" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="amount_currency" type="CHAR(3)">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP WITHOUT TIME ZONE" defaultValueComputed="(now() AT TIME ZONE 'UTC')">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint baseTableName="payment_tx" baseColumnNames="parent_tx_id"
                                 constraintName="fk_payment_tx_parent"
                                 referencedTableName="payment_tx" referencedColumnNames="tx_id"/>

        <!-- Add CHECK constraints using raw SQL since liquibase standard tag doesn't cover all check constraint syntax perfectly in all dialects -->
        <sql>
            ALTER TABLE payment_tx ADD CONSTRAINT chk_tx_type CHECK (tx_type IN ('AUTHORIZATION', 'CAPTURE', 'REFUND', 'SETTLE'));
            ALTER TABLE payment_tx ADD CONSTRAINT chk_tx_amount_positive CHECK (amount_value > 0);
            ALTER TABLE payment_tx ADD CONSTRAINT chk_tx_currency CHECK (amount_currency ~ '^[A-Z]{3}$');
            ALTER TABLE payment_tx ADD CONSTRAINT chk_tx_status CHECK (status IN ('PENDING', 'SUCCESS', 'FAILED'));
            ALTER TABLE payment_tx ADD CONSTRAINT chk_tx_settle_status CHECK (settle_status IS NULL OR settle_status IN ('UNMATCHED', 'MATCHED', 'DISCREPANCY'));
            ALTER TABLE payment_tx ADD CONSTRAINT chk_tx_settle_consistency CHECK ((tx_type = 'SETTLE' AND acquirer_batch_ref IS NOT NULL AND settled_amount_value IS NOT NULL) OR (tx_type != 'SETTLE' AND acquirer_batch_ref IS NULL));
            ALTER TABLE payment_tx ADD CONSTRAINT chk_tx_capture_has_settle_status CHECK ((tx_type = 'CAPTURE' AND settle_status IS NOT NULL) OR (tx_type != 'CAPTURE' OR settle_status IS NULL));
        </sql>

        <createIndex tableName="payment_tx" indexName="idx_payment_tx_payment_id">
            <column name="payment_id"/>
        </createIndex>
        <createIndex tableName="payment_tx" indexName="idx_payment_tx_parent">
            <column name="parent_tx_id"/>
        </createIndex>
        <createIndex tableName="payment_tx" indexName="idx_payment_tx_payment_intent_id">
            <column name="payment_intent_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
