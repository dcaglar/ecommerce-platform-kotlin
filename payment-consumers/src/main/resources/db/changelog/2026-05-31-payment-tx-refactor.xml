<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.3.xsd">

    <!--
        Epic 1 — US 1.2: Refactor payment_tx table
        ============================================================
        Adds columns required by the new Tx sealed hierarchy:
          - status      (TxStatus:  PENDING | SUCCESS | FAILED)
          - settle_status (SettleStatus: UNMATCHED | MATCHED | DISCREPANCY) — nullable, CAPTURE rows only
          - acquirer_batch_ref  (VARCHAR) — nullable, SETTLE rows only
          - settled_amount_value (BIGINT)  — nullable, SETTLE rows only

        Drops the legacy payment_order_id column (no longer exists in domain).
        Adds SETTLE to the tx_type check constraint.
        Drops the legacy idx_payment_tx_po_id index.
    -->

    <!-- ============================================================
         Step 1: Add new columns
         ============================================================ -->
    <changeSet id="2026-05-31-02-payment-tx-add-status" author="dogancaglar">

        <addColumn tableName="payment_tx">
            <!-- TxStatus: PENDING | SUCCESS | FAILED -->
            <column name="status" type="VARCHAR(16)" defaultValue="PENDING">
                <constraints nullable="false"/>
            </column>
        </addColumn>

        <addColumn tableName="payment_tx">
            <!-- SettleStatus: UNMATCHED | MATCHED | DISCREPANCY
                 NULL for AUTHORIZATION and REFUND rows.
                 UNMATCHED on CAPTURE creation; resolved during settlement batch. -->
            <column name="settle_status" type="VARCHAR(16)">
                <constraints nullable="true"/>
            </column>
        </addColumn>

        <addColumn tableName="payment_tx">
            <!-- acquirer batch reference for SETTLE rows only -->
            <column name="acquirer_batch_ref" type="VARCHAR(255)">
                <constraints nullable="true"/>
            </column>
        </addColumn>

        <addColumn tableName="payment_tx">
            <!-- Actual settled amount (may differ from amount_value due to fees) -->
            <column name="settled_amount_value" type="BIGINT">
                <constraints nullable="true"/>
            </column>
        </addColumn>

        <rollback>
            <dropColumn tableName="payment_tx" columnName="status"/>
            <dropColumn tableName="payment_tx" columnName="settle_status"/>
            <dropColumn tableName="payment_tx" columnName="acquirer_batch_ref"/>
            <dropColumn tableName="payment_tx" columnName="settled_amount_value"/>
        </rollback>

    </changeSet>

    <!-- ============================================================
         Step 2: Drop the legacy payment_order_id column
         ============================================================ -->
    <changeSet id="2026-05-31-03-payment-tx-drop-payment-order-id" author="dogancaglar">

        <!-- Drop the index first (required before column drop in PG) -->
        <dropIndex tableName="payment_tx" indexName="idx_payment_tx_po_id"/>

        <dropColumn tableName="payment_tx" columnName="payment_order_id"/>

        <rollback>
            <addColumn tableName="payment_tx">
                <column name="payment_order_id" type="BIGINT">
                    <constraints nullable="true"/>
                </column>
            </addColumn>
            <createIndex tableName="payment_tx" indexName="idx_payment_tx_po_id">
                <column name="payment_order_id"/>
            </createIndex>
        </rollback>

    </changeSet>

    <!-- ============================================================
         Step 3: Update tx_type CHECK constraint to include SETTLE
         ============================================================ -->
    <changeSet id="2026-05-31-04-payment-tx-add-settle-type" author="dogancaglar">
        <sql>
            ALTER TABLE payment_tx DROP CONSTRAINT IF EXISTS chk_tx_type;
            ALTER TABLE payment_tx
                ADD CONSTRAINT chk_tx_type
                    CHECK (tx_type IN ('AUTHORIZATION', 'CAPTURE', 'REFUND', 'SETTLE'));
        </sql>
        <rollback>
            <sql>
                ALTER TABLE payment_tx DROP CONSTRAINT IF EXISTS chk_tx_type;
                ALTER TABLE payment_tx
                    ADD CONSTRAINT chk_tx_type
                        CHECK (tx_type IN ('AUTHORIZATION', 'CAPTURE', 'REFUND'));
            </sql>
        </rollback>
    </changeSet>

    <!-- ============================================================
         Step 4: Add CHECK constraints for new columns
         ============================================================ -->
    <changeSet id="2026-05-31-05-payment-tx-check-status" author="dogancaglar">
        <sql>
            ALTER TABLE payment_tx
                ADD CONSTRAINT chk_tx_status
                    CHECK (status IN ('PENDING', 'SUCCESS', 'FAILED'));

            ALTER TABLE payment_tx
                ADD CONSTRAINT chk_tx_settle_status
                    CHECK (settle_status IS NULL OR
                           settle_status IN ('UNMATCHED', 'MATCHED', 'DISCREPANCY'));

            -- SETTLE rows must have a batch ref; CAPTURE rows must have settle_status
            ALTER TABLE payment_tx
                ADD CONSTRAINT chk_tx_settle_consistency
                    CHECK (
                        (tx_type = 'SETTLE' AND acquirer_batch_ref IS NOT NULL AND settled_amount_value IS NOT NULL)
                            OR
                        (tx_type != 'SETTLE' AND acquirer_batch_ref IS NULL)
                    );

            ALTER TABLE payment_tx
                ADD CONSTRAINT chk_tx_capture_has_settle_status
                    CHECK (
                        (tx_type = 'CAPTURE' AND settle_status IS NOT NULL)
                            OR
                        (tx_type != 'CAPTURE' OR settle_status IS NULL)
                    );
        </sql>
        <rollback>
            <sql>
                ALTER TABLE payment_tx DROP CONSTRAINT IF EXISTS chk_tx_status;
                ALTER TABLE payment_tx DROP CONSTRAINT IF EXISTS chk_tx_settle_status;
                ALTER TABLE payment_tx DROP CONSTRAINT IF EXISTS chk_tx_settle_consistency;
                ALTER TABLE payment_tx DROP CONSTRAINT IF EXISTS chk_tx_capture_has_settle_status;
            </sql>
        </rollback>
    </changeSet>

    <!-- ============================================================
         Step 5: Update default settle_status for existing CAPTURE rows
         ============================================================ -->
    <changeSet id="2026-05-31-06-payment-tx-backfill-settle-status" author="dogancaglar">
        <sql>
            UPDATE payment_tx SET status = 'SUCCESS'  WHERE status IS NULL OR status = 'PENDING';
            UPDATE payment_tx SET settle_status = 'UNMATCHED' WHERE tx_type = 'CAPTURE' AND settle_status IS NULL;
        </sql>
        <rollback>
            <!-- No safe rollback for data migration; columns will be dropped in prior changesets -->
        </rollback>
    </changeSet>

    <!-- ============================================================
         Step 6: Add payment_intent_id column
         ============================================================ -->
    <changeSet id="2026-05-31-07-payment-tx-add-payment-intent-id" author="dogancaglar">
        <addColumn tableName="payment_tx">
            <column name="payment_intent_id" type="BIGINT">
                <!-- Using nullable initially, or default 0, but ideally not null -->
                <constraints nullable="true"/>
            </column>
        </addColumn>
        
        <createIndex tableName="payment_tx" indexName="idx_payment_tx_payment_intent_id">
            <column name="payment_intent_id"/>
        </createIndex>

        <rollback>
            <dropIndex tableName="payment_tx" indexName="idx_payment_tx_payment_intent_id"/>
            <dropColumn tableName="payment_tx" columnName="payment_intent_id"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
