{
  "title": "Payment Platform Load Test Dashboard",
  "uid": "payment-platform-load-test",
  "timezone": "browser",
  "schemaVersion": 36,
  "refresh": "5s",
  "panels": [
    {
      "type": "row",
      "title": "1. Edge API Traffic (payment-edge-cell)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100
    },
    {
      "title": "Global RPS",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 1 },
      "id": 1,
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"payment-service\"}[1m]))",
          "legendFormat": "RPS"
        }
      ]
    },
    {
      "title": "Latency (P95 / P99)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 1 },
      "id": 2,
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{application=\"payment-service\"}[1m])) by (le))",
          "legendFormat": "P95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_server_requests_seconds_bucket{application=\"payment-service\"}[1m])) by (le))",
          "legendFormat": "P99"
        }
      ]
    },
    {
      "title": "HTTP 5xx Error Rate",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 1 },
      "id": 3,
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"payment-service\", status=~\"5..\"}[1m])) / sum(rate(http_server_requests_seconds_count{application=\"payment-service\"}[1m]))",
          "legendFormat": "Error Rate"
        }
      ]
    },
    {
      "type": "row",
      "title": "2. Async Outbox Processing (Edge Workers & Central Relay)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 200
    },
    {
      "title": "Local Outbox Dispatch Rate (Edge -> Central DB)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "id": 4,
      "targets": [
        {
          "expr": "sum(rate(outbox_dispatched_total[1m])) by (application)",
          "legendFormat": "{{application}}"
        }
      ]
    },
    {
      "title": "Central Outbox Relay Rate (Central DB -> Kafka)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "id": 5,
      "targets": [
        {
          "expr": "sum(rate(relay_published_total[1m])) by (application)",
          "legendFormat": "{{application}}"
        }
      ]
    },
    {
      "title": "Outbox & Relay Errors",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 18 },
      "id": 6,
      "targets": [
        {
          "expr": "sum(rate(outbox_dispatch_failed_total[1m])) by (application)",
          "legendFormat": "Local Outbox Errors"
        },
        {
          "expr": "sum(rate(relay_publish_failed_total[1m])) by (application)",
          "legendFormat": "Relay Publish Errors"
        }
      ]
    },
    {
      "title": "Maintenance Job Errors",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 18 },
      "id": 7,
      "targets": [
        {
          "expr": "sum(rate(maintenance_job_error_total[1m])) by (job)",
          "legendFormat": "{{job}}"
        }
      ]
    },
    {
      "type": "row",
      "title": "3. Event Consumers (Kafka & PSP Adapters)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 26 },
      "id": 300
    },
    {
      "title": "Kafka Consumer Lag per Topic",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 27 },
      "id": 8,
      "targets": [
        {
          "expr": "sum(kafka_consumergroup_lag{consumergroup=~\"psp-.*\"}) by (consumergroup)",
          "legendFormat": "{{consumergroup}}"
        }
      ]
    },
    {
      "title": "DLQ Messages (Dead Letter Queue)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 27 },
      "id": 9,
      "targets": [
        {
          "expr": "sum(kafka_consumer_dlq_messages_total) by (topic)",
          "legendFormat": "{{topic}}"
        }
      ]
    },
    {
      "title": "PSP Call Outcomes (Capture & Refund)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 35 },
      "id": 10,
      "targets": [
        {
          "expr": "sum(rate(psp_calls_total[1m])) by (result)",
          "legendFormat": "Capture - {{result}}"
        },
        {
          "expr": "sum(rate(psp_refund_calls_total[1m])) by (result)",
          "legendFormat": "Refund - {{result}}"
        }
      ]
    },
    {
      "type": "row",
      "title": "4. Infrastructure & Database Health",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 43 },
      "id": 400
    },
    {
      "title": "HikariCP Active Connections",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 44 },
      "id": 11,
      "targets": [
        {
          "expr": "sum(hikaricp_connections_active) by (application)",
          "legendFormat": "{{application}}"
        }
      ]
    },
    {
      "title": "HikariCP Pending Connections",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 44 },
      "id": 12,
      "targets": [
        {
          "expr": "sum(hikaricp_connections_pending) by (application)",
          "legendFormat": "{{application}}"
        }
      ]
    },
    {
      "title": "CPU Usage by Pod",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 44 },
      "id": 13,
      "targets": [
        {
          "expr": "sum(rate(container_cpu_usage_seconds_total{namespace=\"payment\", container!=\"POD\", container!=\"\"}[1m])) by (pod)",
          "legendFormat": "{{pod}}"
        }
      ]
    }
  ]
}
